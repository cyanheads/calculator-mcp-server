{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.cyanheads/calculator-mcp-server",
  "description": "A calculator MCP server that lets any LLM verify mathematical computations. Evaluate, simplify, and differentiate expressions via a single tool. Powered by math.js v15.",
  "repository": {
    "url": "https://github.com/cyanheads/calculator-mcp-server",
    "source": "github"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@cyanheads/calculator-mcp-server",
      "runtimeHint": "bun",
      "version": "0.1.1",
      "packageArguments": [
        {
          "type": "positional",
          "value": "run"
        },
        {
          "type": "positional",
          "value": "start:stdio"
        }
      ],
      "environmentVariables": [
        {
          "name": "CALC_MAX_EXPRESSION_LENGTH",
          "description": "Maximum allowed expression string length.",
          "format": "string",
          "isRequired": false,
          "default": "1000"
        },
        {
          "name": "CALC_EVALUATION_TIMEOUT_MS",
          "description": "Maximum evaluation time in milliseconds.",
          "format": "string",
          "isRequired": false,
          "default": "5000"
        },
        {
          "name": "MCP_LOG_LEVEL",
          "description": "Sets the minimum log level for output (e.g., 'debug', 'info', 'warn').",
          "format": "string",
          "isRequired": false,
          "default": "info"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@cyanheads/calculator-mcp-server",
      "runtimeHint": "bun",
      "version": "0.1.1",
      "packageArguments": [
        {
          "type": "positional",
          "value": "run"
        },
        {
          "type": "positional",
          "value": "start:http"
        }
      ],
      "environmentVariables": [
        {
          "name": "CALC_MAX_EXPRESSION_LENGTH",
          "description": "Maximum allowed expression string length.",
          "format": "string",
          "isRequired": false,
          "default": "1000"
        },
        {
          "name": "CALC_EVALUATION_TIMEOUT_MS",
          "description": "Maximum evaluation time in milliseconds.",
          "format": "string",
          "isRequired": false,
          "default": "5000"
        },
        {
          "name": "MCP_HTTP_HOST",
          "description": "The hostname for the HTTP server.",
          "format": "string",
          "isRequired": false,
          "default": "127.0.0.1"
        },
        {
          "name": "MCP_HTTP_PORT",
          "description": "The port to run the HTTP server on.",
          "format": "string",
          "isRequired": false,
          "default": "3010"
        },
        {
          "name": "MCP_HTTP_ENDPOINT_PATH",
          "description": "The endpoint path for the MCP server.",
          "format": "string",
          "isRequired": false,
          "default": "/mcp"
        },
        {
          "name": "MCP_AUTH_MODE",
          "description": "Authentication mode to use: 'none', 'jwt', or 'oauth'.",
          "format": "string",
          "isRequired": false,
          "default": "none"
        },
        {
          "name": "MCP_LOG_LEVEL",
          "description": "Sets the minimum log level for output (e.g., 'debug', 'info', 'warn').",
          "format": "string",
          "isRequired": false,
          "default": "info"
        }
      ],
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:3010/mcp"
      }
    }
  ]
}
